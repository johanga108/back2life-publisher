# Telegram: add the bot to the channel as an administrator.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# VK: publishing goes through the official Postmypost REST API.
# Project and account IDs are optional when only one connected VK account exists.
POSTMYPOST_ACCESS_TOKEN=
POSTMYPOST_PROJECT_ID=
POSTMYPOST_VK_ACCOUNT_ID=
POSTMYPOST_API_BASE=https://api.postmypost.io/v4.1

# Instagram Professional account.
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_API_VERSION=v25.0

# Cloudinary: public image hosting for Instagram publishing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Facebook Page is optional. Personal profiles cannot be published through the API.
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
FB_GRAPH_API_VERSION=v25.0

# Add vk only after the Postmypost token check passes.
ENABLED_PLATFORMS=telegram,instagram

# Editable content source: sheet Codex with date, title and post text columns.
CONTENT_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/gviz/tq?tqx=out:csv&sheet=Codex
